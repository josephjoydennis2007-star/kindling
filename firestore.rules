rules_version = '2';

// Kindling Studio — Firestore security rules.
//
// Paste this entire file into Firebase Console:
//   1. Go to https://console.firebase.google.com → kindling-1d29d
//   2. Left sidebar → Firestore Database
//   3. Top tab → Rules
//   4. Replace everything with the contents of this file
//   5. Click "Publish"
//
// What these rules guarantee:
//   - A story document can only be READ by its owner OR users on the
//     story's `collaborators` array OR (if it's marked `shareable: true`)
//     any signed-in user.
//   - A story can only be WRITTEN by its owner OR users on the
//     `collaborators` array. Adding/removing collaborators is owner-only.
//   - Profiles are public-readable so collaborators can see each other's
//     names + avatars, but only the owner can write their own.
//   - The /presence collection (used in Round 3 for who's-online) lets
//     each signed-in user write their own presence doc.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Stories ──────────────────────────────────────────────────────
    // Doc id is the story's id. Fields:
    //   owner       — uid of the creator
    //   collaborators — array of uids (can write)
    //   shareable   — bool: if true, any signed-in user can read
    //   data        — the actual story payload (screenplay, scenes, ...)
    //   updatedAt   — serverTimestamp()
    match /stories/{storyId} {
      // `resource == null` allows reads of stories that DON'T EXIST yet.
      // Without this, getDoc() on a brand-new storyId returns
      // permission-denied (because the conditions below reference
      // resource.data which is null), breaking the standard "check exists,
      // then create or update" pattern in client code. Allowing null reads
      // is a sanctioned Firestore pattern — it leaks at most the existence
      // of arbitrary IDs, not any actual data, and the client only ever
      // looks up IDs it already knows from its local IndexedDB.
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.owner == request.auth.uid ||
        request.auth.uid in resource.data.get('collaborators', []) ||
        resource.data.get('shareable', false) == true
      );
      // Anyone signed in can CREATE a story they own.
      allow create: if request.auth != null
                    && request.resource.data.owner == request.auth.uid;
      // ── Update permissions ──
      // Split into three INDEPENDENT `allow update` statements so a
      // condition error in one branch can't error-cascade and block
      // the others. Firestore treats multiple `allow` statements for
      // the same operation as OR: if ANY passes, the update is allowed.

      // (1) Owner can do anything. Short and simple — no get(), no
      //     array math, no map comparison. Owners hit this first.
      allow update: if request.auth != null
                    && resource.data.owner == request.auth.uid;

      // (2) Existing collaborator can update the data slice. They
      //     cannot touch owner / collaborators / shareable /
      //     collaboratorRoles. Defensive .get() defaults so missing
      //     fields don't error.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.get('collaborators', [])
                    && request.resource.data.owner == resource.data.owner
                    && request.resource.data.collaborators == resource.data.collaborators
                    && request.resource.data.shareable == resource.data.shareable
                    && request.resource.data.get('collaboratorRoles', {})
                       == resource.data.get('collaboratorRoles', {});

      // (3) Self-join via matching invite. Invitee adds themselves to
      //     collaborators AND sets their own role to whatever the invite
      //     specified. The role match prevents self-elevation.
      allow update: if request.auth != null
                    && request.resource.data.owner == resource.data.owner
                    && request.resource.data.shareable == resource.data.shareable
                    && !(request.auth.uid in resource.data.get('collaborators', []))
                    && (request.auth.uid in request.resource.data.collaborators)
                    && request.resource.data.collaborators.size()
                       == resource.data.get('collaborators', []).size() + 1
                    && exists(/databases/$(database)/documents/invites/$(storyId + '__' + request.auth.token.email.lower()))
                    && request.resource.data.collaboratorRoles[request.auth.uid]
                       == get(/databases/$(database)/documents/invites/$(storyId + '__' + request.auth.token.email.lower())).data.get('role', 'both');
      // Only the owner can delete.
      allow delete: if request.auth != null
                    && resource.data.owner == request.auth.uid;
    }

    // ── Invites ──────────────────────────────────────────────────────
    // Doc id = autogen. Fields: storyId, fromUid, toEmail, status,
    // createdAt. Used so an owner can "invite by email" before the
    // invitee has signed up.
    match /invites/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if request.auth != null && (
        // Inviter can cancel
        resource.data.fromUid == request.auth.uid ||
        // Invitee can accept/decline
        resource.data.toEmail == request.auth.token.email
      );
      allow delete: if request.auth != null
                    && resource.data.fromUid == request.auth.uid;
    }

    // ── Profiles ─────────────────────────────────────────────────────
    // Doc id = uid. Public-readable so collaborators see each other's
    // names + avatars; only the owner can write.
    match /profiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Profiles by email (lookup index for invites) ─────────────────
    // Mirror of /profiles keyed by lowercased email so the InviteDialog
    // can find a person by email and preview their role + accept-opposite
    // preference. The owning user writes their own mirror via upsertProfile.
    // Any signed-in user can read (so inviters can do the lookup), but only
    // the matching uid can write their own row.
    match /profilesByEmail/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.uid == request.auth.uid;
    }

    // ── Presence (Round 3) ───────────────────────────────────────────
    // Each user writes their own presence doc inside a story.
    // Path: /stories/{storyId}/presence/{uid}
    match /stories/{storyId}/presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Chat (Round 3) ───────────────────────────────────────────────
    // Real-time chat messages between collaborators on a story. Path:
    //   /stories/{storyId}/chat/{msgId}
    // Rules: only the story's owner OR users in its `collaborators`
    // array can read or post messages. Messages are immutable once
    // posted (no update / delete). The author field on each message
    // must match the current user's uid so nobody can spoof another.
    //
    // NOTE: we use .get('collaborators', []) so a story doc that
    // somehow lost its collaborators field still evaluates safely
    // (it just means only the owner can chat — fail-safe).
    match /stories/{storyId}/chat/{msgId} {
      function storyData() {
        return get(/databases/$(database)/documents/stories/$(storyId)).data;
      }
      function isStoryMember() {
        let s = storyData();
        return s.owner == request.auth.uid
            || request.auth.uid in s.get('collaborators', []);
      }
      allow read: if request.auth != null && isStoryMember();
      allow create: if request.auth != null && isStoryMember()
                    && request.resource.data.authorId == request.auth.uid;
      // No updates or deletes — chat history is append-only.
    }

    // ── Comments (Producer + everyone) ──────────────────────────────
    // /stories/{storyId}/comments/{commentId}
    // Any story member (owner, writer, director, producer, both) can
    // read + post. Authors can edit their own comments (resolve flag
    // or text). Author can delete; the story owner can also delete
    // any comment so they can clean up.
    match /stories/{storyId}/comments/{commentId} {
      function storyData() {
        return get(/databases/$(database)/documents/stories/$(storyId)).data;
      }
      function isStoryMember() {
        let s = storyData();
        return s.owner == request.auth.uid
            || request.auth.uid in s.get('collaborators', []);
      }
      allow read: if request.auth != null && isStoryMember();
      allow create: if request.auth != null && isStoryMember()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && isStoryMember()
                    && resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.authorId == request.auth.uid
        || storyData().owner == request.auth.uid
      );
    }

    // ── Version history (snapshots) ──────────────────────────────────
    // /stories/{storyId}/versions/{versionId}
    // Any story member can read snapshots + create new ones, and delete
    // (used to prune old snapshots). Snapshots are immutable (no update).
    match /stories/{storyId}/versions/{versionId} {
      function storyData() {
        return get(/databases/$(database)/documents/stories/$(storyId)).data;
      }
      function isStoryMember() {
        let s = storyData();
        return s.owner == request.auth.uid
            || request.auth.uid in s.get('collaborators', []);
      }
      allow read, create, delete: if request.auth != null && isStoryMember();
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
