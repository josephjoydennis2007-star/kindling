rules_version = '2';

// Kindling — Firebase Storage security rules.
//
// Media (storyboard frames, last frames, b-roll frames, character art, asset
// uploads, and later videos) live under users/{uid}/... Each user can read +
// write ONLY their own folder. Files are served via long-lived download URLs
// (getDownloadURL) which embed an unguessable token, so a story shared with a
// collaborator still renders its images via those URLs.
//
// Paste into Firebase Console → Storage → Rules, or deploy with:
//   firebase deploy --only storage

service firebase.storage {
  match /b/{bucket}/o {
    // A user's own media folder — full control.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   // Guard against runaway uploads: 50 MB per object (plenty for
                   // images; videos should be hosted by Runway and referenced
                   // by URL rather than uploaded here).
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
