# Kindling — Firebase configuration template.
#
# Copy this file to `.env` (same folder, no extension) and paste in the
# real values from your Firebase project. The .env file is git-ignored so
# your keys never leave this machine.
#
# Where to find each value:
#   1. Go to https://console.firebase.google.com
#   2. Open your project (or create one called "kindling")
#   3. Click the gear icon (top-left) → Project settings
#   4. Scroll to "Your apps" → Web (</>) app
#   5. If no web app yet: click "Add app" → Web → register a nickname
#   6. The "SDK setup" → "Config" block shows all 6 values below.
#
# After saving .env, restart `npm run dev` so Vite picks up the new env.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
